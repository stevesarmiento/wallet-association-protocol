{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@wallet-association/core": ["packages/core/src/index.ts"],
      "@wallet-association/transport-localhost": ["packages/transport-localhost/src/index.ts"],
      "@wallet-association/wallet-standard": ["packages/wallet-standard/src/index.ts"]
    }
  }
}
