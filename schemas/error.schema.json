{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wallet-association.dev/schemas/v0.1/error.schema.json",
  "type": "object",
  "required": ["error"],
  "additionalProperties": false,
  "properties": {
    "error": {
      "type": "object",
      "required": ["code", "message"],
      "additionalProperties": false,
      "properties": {
        "code": {
          "enum": [
            "invalid_origin",
            "malformed_request",
            "request_too_large",
            "session_invalid",
            "user_rejected",
            "unsupported_method",
            "unsupported_protocol",
            "bridge_unavailable",
            "not_found"
          ]
        },
        "message": { "type": "string" },
        "details": {}
      }
    }
  }
}
