{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://wallet-association.dev/schemas/v0.2/connection-uri.schema.json",
  "type": "object",
  "required": ["version", "transport", "relay", "room", "secret", "origin", "expiresAt"],
  "additionalProperties": false,
  "properties": {
    "version": { "const": "2" },
    "transport": { "const": "relay" },
    "relay": { "type": "string", "pattern": "^wss?://" },
    "room": { "type": "string", "minLength": 1 },
    "secret": { "type": "string", "minLength": 1 },
    "origin": { "type": "string", "pattern": "^https?://" },
    "expiresAt": { "type": "string", "format": "date-time" }
  }
}
