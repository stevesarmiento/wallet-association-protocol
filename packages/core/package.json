{
  "name": "@wallet-association/core",
  "version": "0.1.0",
  "description": "Core Wallet Association Protocol types, crypto, envelopes, and validation.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist/**"
  ],
  "scripts": {
    "build": "tsup",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@noble/ciphers": "1.3.0",
    "@noble/curves": "1.9.7",
    "@noble/hashes": "1.8.0"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
  },
  "license": "MIT"
}
